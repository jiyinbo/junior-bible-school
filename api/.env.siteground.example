# SiteGround production template — copy to `.env` on the server (inside `api/`, never in `public_html`).
# Use placeholders below for DB credentials; never commit real passwords to git.
#
# On the server after upload:
#   php artisan migrate --force
#   php artisan key:generate --force   # only if APP_KEY is empty or you want a new key
#
# MySQL: Site Tools → MySQL

APP_NAME="Junior Bible School API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://jbs-api.winners-chapel.org.uk
JBS_STUDENT_PORTAL_URL=https://jbs.winners-chapel.org.uk/student
JBS_CONTACT_EMAIL=dartford.jbs@winners-chapel.org.uk

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=dbaqgkdamq3iog
DB_USERNAME=PASTE_SITEGROUND_MYSQL_USER
DB_PASSWORD=PASTE_SITEGROUND_MYSQL_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USERNAME=PASTE_M365_MAILBOX_ADDRESS
MAIL_PASSWORD=PASTE_M365_SMTP_PASSWORD_OR_APP_PASSWORD
MAIL_FROM_ADDRESS="PASTE_M365_MAILBOX_ADDRESS"
MAIL_FROM_NAME="${APP_NAME}"

# Microsoft 365 SMTP — IT must provide a dedicated sender mailbox (e.g. jbs-noreply@winners-chapel.org.uk)
# with SMTP AUTH enabled. MAIL_USERNAME and MAIL_FROM_ADDRESS must match that mailbox.
# Store credentials only in server .env (never commit).

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# First deploy on server: run `php artisan key:generate --force` if you prefer a fresh APP_KEY.
# If DB_HOST errors on SiteGround, try the host shown in Site Tools → MySQL (sometimes not "localhost").
