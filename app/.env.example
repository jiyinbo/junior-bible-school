# Copy to `.env` — Vite does NOT read this file. Restart dev server after changes.
#
# Use production API from your machine (no local Laravel):
#   VITE_API_URL=https://jbs-api.winners-chapel.org.uk
#
# Use local Laravel via Vite proxy (php artisan serve on :8000) — omit or comment out:
#   # VITE_API_URL=

# Production builds use `.env.production` (see npm run build).
